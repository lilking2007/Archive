{
  "manifest_version": 3,
  "name": "NoteMind — AI Meeting Notes",
  "version": "1.0.0",
  "description": "Record meetings with 95%+ accurate transcription, speaker detection, and AI-powered notes. Works with Google Meet, Zoom, Teams, and any browser meeting.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "http://localhost:8765/*",
    "ws://localhost:8765/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
